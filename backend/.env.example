# 환경변수 템플릿. 실제 값은 backend/.env 에 작성한다(.gitignore 처리됨).
# 새 키 생성: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# 토스증권 Open API (F400 시세). 발급받은 client 자격증명을 입력.
TOSS_API_BASE=https://openapi.tossinvest.com
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
# 시세 캐시 TTL(초). 같은 종목 반복 조회 시 외부 호출을 줄임.
TOSS_QUOTE_TTL_SECONDS=30
