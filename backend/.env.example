# 환경변수 템플릿. 실제 값은 backend/.env 에 작성한다(.gitignore 처리됨).
# 새 키 생성: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# 토스증권 Open API (F400 시세). 발급받은 client 자격증명을 입력.
TOSS_API_BASE=https://openapi.tossinvest.com
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
# 시세 캐시 TTL(초). 같은 종목 반복 조회 시 외부 호출을 줄임.
TOSS_QUOTE_TTL_SECONDS=30

# SSAFY GMS API (F300 추천 이유 생성). 키 미설정 시 규칙기반 템플릿으로 폴백.
# OpenAI Responses API를 GMS 프록시 경로로 호출:
# https://gms.ssafy.io/gmsapi/api.openai.com/v1/responses
GMS_API_BASE=https://gms.ssafy.io/gmsapi
GMS_API_KEY=
GMS_MODEL=gpt-4.1

# 추천 이유에 포함할 종목별 뉴스 요약. RSS 수집 실패 시 추천은 계속 진행됨.
NEWS_SUMMARY_ENABLED=true
NEWS_SUMMARY_TTL_HOURS=6
NEWS_SUMMARY_LIMIT=5
NEWS_SUMMARY_TIMEOUT_SECONDS=5
NEWS_RSS_BASE=https://news.google.com/rss/search
